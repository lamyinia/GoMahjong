{
  "server": {
    "node_id": "game-node-001",
    "host": "127.0.0.1",
    "service_name": "game-service",
    "net": {
      "tcp": {
        "port": 8010,
        "max_frame_bytes": 65536,
        "idle_timeout_seconds": 60
      }
    },
    "log": {
      "level": "debug",
      "short_source": true
    },
    "etcd": {
      "endpoints": "http://127.0.0.1:2379",
      "ttl_seconds": 10,
      "report_interval_seconds": 5
    },
    "grpc": {
      "port": 9010
    },
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "gomahjong",
      "min_pool_size": 10,
      "max_pool_size": 100,
      "thread_count": 4,
      "queue_max_size": 1000
    },
    "debug": {
      "enabled": true
    },
    "timer_wheel": {
      "tick_duration_ms": 50,
      "wheel_size": 512
    }
  }
}

