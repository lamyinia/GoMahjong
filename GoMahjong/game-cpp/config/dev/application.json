{
  "server": {
    "node_id": "game-node-001",
    "host": "127.0.0.1",
    "service_name": "game-instance",
    "net": {
      "tcp": {
        "port": 8010,
        "max_frame_bytes": 65536,
        "idle_timeout_seconds": 60
      }
    },
    "log": {
      "level": "debug",
      "short_source": true
    },
    "etcd": {
      "endpoints": "http://127.0.0.1:2379",
      "ttl_seconds": 10,
      "report_interval_seconds": 5
    },
    "grpc": {
      "port": 9010
    },
    "mongodb": {
      "uri": "mongodb://localhost:27017",
      "database": "gomahjong",
      "min_pool_size": 10,
      "max_pool_size": 100,
      "thread_count": 4,
      "queue_max_size": 1000
    },
    "debug": {
      "enabled": true
    },
    "timer_wheel": {
      "tick_duration_ms": 50,
      "wheel_size": 512
    },
    "game": {
      "riichi_mahjong_4p": {
        "player_count": 4,
        "initial_points": 25000,
        "total_time": 300,
        "compensation": 5,
        "max_round_time": 30,
        "react_compensation": 5,
        "round_start_delay_ms": 10000
      }
    }
  }
}
